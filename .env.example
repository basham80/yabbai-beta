# Environment variables for AI mission proxy (never commit real keys).
#
# ─ Cloudflare Workers (recommended with 4EVERLAND static hosting) ─
#   npx wrangler secret put ANTHROPIC_API_KEY
#   npx wrangler secret put MOONSHOT_API_KEY
# Optional plain vars in wrangler.toml [vars] section:
#   ANTHROPIC_MODEL, MOONSHOT_MODEL, MOONSHOT_API_BASE
#
# ─ Netlify Functions (if using Netlify instead) ─
# Set the same names in Netlify → Site → Environment variables.
#
# ─ Local Netlify dev ─
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=
